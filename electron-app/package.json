{
  "name": "vibeconferencing-agent",
  "productName": "Vibeconferencing",
  "version": "0.7.0-beta1",
  "description": "AI bot that joins Google Meet calls — Electron wrapper",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "dev-with-tools": "electron . --devtools=true",
    "pack": "electron-builder --dir",
    "dist": "electron-builder && tccutil reset All com.vibeconferencing.agent",
    "dist:fast": "electron-builder -c.mac.notarize=false && tccutil reset All com.vibeconferencing.agent"
  },
  "build": {
    "appId": "com.vibeconferencing.agent",
    "productName": "Vibeconferencing",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "notarize": {
        "teamId": "PNPVJ6J7X2"
      },
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Vibeconferencing needs microphone access to enable bot audio in Google Meet calls.",
        "NSCameraUsageDescription": "Vibeconferencing needs camera access to display the bot's virtual camera in Google Meet calls."
      }
    },
    "files": [
      "main.js",
      "store.js",
      "local-server.js",
      "preferences-schema.js",
      "session-log.js",
      "svg-resolver.js",
      "preload-meet.js",
      "preload-panel.js",
      "renderer/**/*",
      "icon.png"
    ],
    "extraResources": [
      {
        "from": "../extension",
        "to": "extension",
        "filter": [
          "*.js",
          "*.mp3"
        ]
      },
      {
        "from": "../mcp-server",
        "to": "mcp-server",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}
