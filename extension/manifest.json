{
  "manifest_version": 3,
  "name": "Bots in Calls",
  "description": "AI bots that join Google Meet calls as virtual participants",
  "version": "0.1.0",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "sidePanel",
    "scripting",
    "webNavigation"
  ],
  "host_permissions": [
    "https://api.elevenlabs.io/*",
    "https://vibeconferencing.com/*",
    "https://*.vibeconferencing.com/*",
    "https://vibeconferencing.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["test-speech.mp3", "whiteboard.html"],
      "matches": ["https://meet.google.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content-script.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["page-inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
