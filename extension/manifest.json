{
  "manifest_version": 3,
  "name": "Vibeconferencing Agent",
  "description": "AI agent that joins Google Meet calls as a virtual participant",
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "version": "0.1.0",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://api.elevenlabs.io/*",
    "https://vibeconferencing.com/*",
    "https://*.vibeconferencing.com/*",
    "https://vibeconferencing.vercel.app/*"
  ],
  "action": {
    "default_popup": "settings.html"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["test-speech.mp3", "whiteboard.html"],
      "matches": ["https://meet.google.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content-script.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["page-inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
